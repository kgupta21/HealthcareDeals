---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not found | Healthcare Deals Canada" description="Page not found.">
  <section class="page-wrap">
    <div class="detail-hero detail-hero--compact">
      <span class="section-kicker">404</span>
      <h1 class="directory-title detail-title">That promotion page is not in the current public directory.</h1>
      <p class="directory-subtitle detail-subtitle">
        Expired offers are removed from the live listing. Return to the tracker to browse the latest verified entries.
      </p>
      <div class="detail-actions">
        <a class="btn-primary" href="/">Back to current deals</a>
      </div>
    </div>
  </section>
</BaseLayout>
