---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not found | Healthcare Deals Canada" description="Page not found.">
  <section class="hero hero--compact">
    <div class="hero-main">
      <span class="hero-tag">404</span>
      <h1>That promotion page is not in the current public directory.</h1>
      <p class="hero-sub">
        Expired offers are removed from the live listing. Return to the tracker to browse the latest verified entries.
      </p>
      <div class="hero-cta">
        <a class="btn-primary" href="/">Back to current deals</a>
      </div>
    </div>
  </section>
</BaseLayout>
