{
  "name": "healthcaredeals",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "preview:pages": "wrangler pages dev ./dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "update:promotions": "tsx scripts/update-promotions.ts",
    "update:promotions:dry": "tsx scripts/update-promotions.ts --dry-run"
  },
  "devDependencies": {
    "@types/node": "25.5.2",
    "astro": "6.1.5",
    "cheerio": "1.2.0",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4",
    "wrangler": "4.81.1",
    "zod": "4.3.6"
  }
}
